# ComfyUI 地址 (預設本地)
COMFYUI_URL=http://127.0.0.1:8188

# TronGrid API Key (免費: https://developers.trongrid.io)
TRONGRID_API_KEY=

# 收款 USDT TRC-20 錢包地址
YOUR_WALLET=Txxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 每次修改費用 (USDT)
PAYMENT_AMOUNT=5

# Flask 伺服器設定
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=your-secret-key-here-change-this

# 訂單過期時間 (分鐘)
ORDER_EXPIRE=30

# ComfyUI Workflow 設定 (留空使用預設)
CUSTOM_WORKFLOW=
